# Coverage configuration for S级/A级 modules only
# Usage: make coverage-sa
#
# Module Classification:
#   S级 (Critical):  Core utilities with high risk of cascading failures
#   A级 (Core):      Primary business logic modules
#   B级 (Standard):  Feature modules - use contract tests
#   C级 (Exclude):   Experimental/legacy - excluded from coverage

[run]
source =
    src/copaw/constant.py
    src/copaw/utils/logging.py
    src/copaw/utils/telemetry.py
    src/copaw/providers/
    src/copaw/security/tool_guard/
    src/copaw/tokenizer/

branch = true
parallel = true
omit =
    */tests/*
    */test/*
    */__pycache__/*
    src/copaw/console/*
    src/copaw/agents/memory/*

[report]
# S级: 80%+, A级: 70%+
# Currently not enforced, informational only
# fail_under = 60

exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    pass
    \.\.\.

precision = 2
show_missing = true
skip_covered = false

[html]
directory = htmlcov-sa

[xml]
output = coverage-sa.xml
