# =============================================================================
# CoPaw Environment Variables Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# -----------------------------------------------------------------------------
# Authentication Configuration
# -----------------------------------------------------------------------------
# Enable/disable authentication for the console
# Set to "true", "1", or "yes" to enable authentication
# If enabled, users must log in before accessing the console
COPAW_AUTH_ENABLED=true

# Optional: Auto-register admin user from environment variables
# Useful for Docker/Kubernetes deployments where interactive registration is not practical
# Leave empty to use web-based registration flow
COPAW_AUTH_USERNAME=
COPAW_AUTH_PASSWORD=

# -----------------------------------------------------------------------------
# Supabase Configuration (Optional)
# -----------------------------------------------------------------------------
# Required only if using Supabase for authentication or database
# Get these values from your Supabase project settings
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
# API base URL for the frontend
# Leave empty for same-origin (frontend and backend served together)
# Set to backend URL if frontend is served separately
VITE_API_BASE_URL=

# Hot Module Replacement (HMR) configuration for development
# Only needed when using Vite dev server behind a proxy/tunnel
VITE_HMR_HOST=
VITE_HMR_PROTOCOL=wss
VITE_HMR_CLIENT_PORT=443

# Auth callback and redirect URLs for website
VITE_AUTH_CALLBACK_URL=/auth/callback
VITE_LOGIN_REDIRECT_URL=/console/chat

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------
# Working directory for agent data and logs
# Default: ./working
COPAW_WORKING_DIR=

# Secret directory for sensitive data (auth.json, etc.)
# Default: ./working.secret
COPAW_SECRET_DIR=

# API server host and port
# Default: 0.0.0.0:8088
COPAW_HOST=0.0.0.0
COPAW_PORT=8088

# Log level: debug, info, warning, error
# Default: info
COPAW_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Model Provider Configuration
# -----------------------------------------------------------------------------
# OpenAI API configuration
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

# Anthropic API configuration
ANTHROPIC_API_KEY=

# Other provider API keys (add as needed)
# AZURE_OPENAI_API_KEY=
# GOOGLE_API_KEY=
# COHERE_API_KEY=

# -----------------------------------------------------------------------------
# Channel Configuration (Optional)
# -----------------------------------------------------------------------------
# Discord bot token
DISCORD_BOT_TOKEN=

# Telegram bot token
TELEGRAM_BOT_TOKEN=

# Slack bot token
SLACK_BOT_TOKEN=

# DingTalk configuration
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=

# WeChat Work configuration
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=

# -----------------------------------------------------------------------------
# Database Configuration (Optional)
# -----------------------------------------------------------------------------
# PostgreSQL connection string (if using external database)
DATABASE_URL=

# Redis connection string (if using Redis for caching)
REDIS_URL=

# -----------------------------------------------------------------------------
# Monitoring & Observability (Optional)
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking
SENTRY_DSN=

# Prometheus metrics endpoint
PROMETHEUS_ENABLED=false

# -----------------------------------------------------------------------------
# Development Configuration
# -----------------------------------------------------------------------------
# Enable debug mode (more verbose logging, hot reload, etc.)
DEBUG=false

# Enable CORS for development
CORS_ENABLED=false
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# JWT secret for token signing (auto-generated if not set)
JWT_SECRET=

# Session timeout in seconds (default: 7 days)
SESSION_TIMEOUT=604800

# Maximum file upload size in MB
MAX_UPLOAD_SIZE_MB=100

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
# Enable experimental features
ENABLE_VOICE_TRANSCRIPTION=false
ENABLE_MCP_SERVERS=true
ENABLE_SKILL_SCANNER=true
