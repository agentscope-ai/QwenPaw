{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "qwenpaw-console",
  "version": "0.1.0",
  "identifier": "com.qwenpaw.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun dev",
    "beforeBuildCommand": "bun build:prod"
  },
  "app": {
    "windows": [
      {
        "title": "qwenpaw-console",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["qwenpaw-backend"]
  }
}
