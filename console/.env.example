# API base URL for the QwenPaw backend.
# Leave empty when the frontend and backend are served together (same origin),
# or in Tauri desktop builds where the port is discovered at runtime via Tauri IPC.
# In Tauri runtime, a non-empty value bypasses backend_port IPC and logs a warning.
# Set to e.g. http://localhost:8088 when running the frontend dev server separately.
VITE_API_BASE_URL=
